{
  "name": "AI Session Manager",
  "short_name": "Sessions",
  "description": "Browse, search, and resume your local AI coding CLI sessions (Claude Code, Codex, Grok, opencode, Cursor, and more) in one place.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
